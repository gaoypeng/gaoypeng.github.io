<?xml version="1.0"?>
<robot name="eyeglasses_8">
  <link name="frame">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/frame.obj" />
      </geometry>
    </visual>
  </link>
  <link name="leftTemple">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/leftTemple.obj" />
      </geometry>
      <origin xyz="44.0 0.0 0.0" rpy="0.0 0.0 0.0" />
    </visual>
  </link>
  <link name="rightTemple">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/rightTemple.obj" />
      </geometry>
      <origin xyz="-44.0 0.0 0.0" rpy="0.0 0.0 0.0" />
    </visual>
  </link>
  <joint name="frame_to_leftTemple_hinge" type="revolute">
    <parent link="frame" />
    <child link="leftTemple" />
    <origin xyz="-44.0 0.0 0.0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="0.0" upper="2.2" effort="1.0" velocity="1.0" />
  </joint>
  <joint name="frame_to_rightTemple_hinge" type="revolute">
    <parent link="frame" />
    <child link="rightTemple" />
    <origin xyz="44.0 0.0 0.0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="0.0" upper="2.2" effort="1.0" velocity="1.0" />
  </joint>
</robot>
