<?xml version='1.0' encoding='utf-8'?>
<robot name="a_stapler_5">
  <link name="base">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/base_refined.obj" />
      </geometry>
    </visual>
  </link>
  <link name="arm">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/arm_refined.obj" />
      </geometry>
      <origin xyz="4.5 -1.5 0.0" rpy="0.0 0.0 0.0" />
    </visual>
  </link>
  <link name="hingePin">
    <visual>
      <geometry>
        <mesh filename="obj_parts/group_output/hingePin_refined.obj" />
      </geometry>
    </visual>
  </link>
  <joint name="base_to_hingePin" type="fixed">
    <parent link="base" />
    <child link="hingePin" />
    
    
  </joint>
  <joint name="stapler_hinge" type="revolute">
    <parent link="base" />
    <child link="arm" />
    <origin xyz="-4.5 1.5 0.0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="0.0" upper="1.3" effort="20.0" velocity="2.0" />
  </joint>
</robot>